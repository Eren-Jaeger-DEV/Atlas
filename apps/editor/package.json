{
  "name": "@atlas/editor",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas Studio AI-native Editor Shell",
  "author": "Eren-Jaeger-DEV",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eren-Jaeger-DEV/Atlas.git"
  },
  "main": "./electron-dist/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "electron": "electron .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder --dir",
    "dist": "electron-builder",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atlas/agents": "workspace:*",
    "@atlas/core": "workspace:*",
    "@atlas/graph": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "monaco-languageclient": "^10.7.0",
    "node-pty": "^1.1.0",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript-language-server": "^5.3.0",
    "vscode-ws-jsonrpc": "^3.5.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3",
    "vite": "^6.0.7"
  }
}

{
  "appId": "com.atlas.studio",
  "productName": "AtlasStudio",
  "asar": true,
  "publish": null,
  "directories": {
    "output": "dist-app"
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true
  }
}

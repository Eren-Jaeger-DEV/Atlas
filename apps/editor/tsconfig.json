{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "exactOptionalPropertyTypes": false
  },
  "references": [
    { "path": "../../packages/core" }
  ],
  "include": ["src/**/*"]
}

    "@atlas/graph": "workspace:*",
    "@atlas/parser": "workspace:*",
    "@atlas/agents": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "cli-table3": "^0.6.5",
    "boxen": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7"
  }
}

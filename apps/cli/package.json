{
  "name": "@atlas/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "atlas": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",

# Normalize line endings to LF for all text files
* text=auto eol=lf

# Force LF for source code
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.css    text eol=lf

# Binary — no line ending conversion
*.wasm   binary
*.png    binary
*.jpg    binary
*.ico    binary
*.db     binary
